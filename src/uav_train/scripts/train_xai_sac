#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PACKAGE_NAME="uav_train"
SOURCE_ENV_CONFIG="$SCRIPT_DIR/../../../config/uav_env.sh"
INSTALL_ENV_CONFIG="$SCRIPT_DIR/../../share/$PACKAGE_NAME/config/uav_env.sh"

if [[ -n "${UAV_ENV_CONFIG:-}" ]]; then
  ENV_CONFIG="$UAV_ENV_CONFIG"
elif [[ -f "$SOURCE_ENV_CONFIG" ]]; then
  ENV_CONFIG="$SOURCE_ENV_CONFIG"
elif [[ -f "$INSTALL_ENV_CONFIG" ]]; then
  ENV_CONFIG="$INSTALL_ENV_CONFIG"
else
  echo "Could not find uav_env.sh. Set UAV_ENV_CONFIG=/path/to/uav_env.sh." >&2
  exit 127
fi

if [[ ! -f "$ENV_CONFIG" ]]; then
  echo "UAV_ENV_CONFIG points to a missing file: $ENV_CONFIG" >&2
  exit 127
fi

source "$ENV_CONFIG"
: "${UAV_CONDA_ENV:?UAV_CONDA_ENV must be set in $ENV_CONFIG}"

if ! command -v conda >/dev/null 2>&1; then
  echo "conda command not found. Initialize conda or add it to PATH before running this wrapper." >&2
  exit 127
fi

exec conda run --no-capture-output -n "$UAV_CONDA_ENV" python -m uav_train.train "$@"
